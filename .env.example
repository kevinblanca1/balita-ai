# Which LLM backend to use: openai | gemini | openrouter | ollama
LLM_PROVIDER=openai

# Optional: model to use. Falls back to the selected provider's default when unset.
# openai=gpt-4o-mini  gemini=gemini-2.0-flash  openrouter=openai/gpt-4o-mini  ollama=llama3.1
# LLM_MODEL=

# --- Provider credentials (only the selected provider's key is required) ---
OPENAI_API_KEY=sk-...                      # LLM_PROVIDER=openai
GEMINI_API_KEY=                            # LLM_PROVIDER=gemini
OPENROUTER_API_KEY=                        # LLM_PROVIDER=openrouter
OLLAMA_BASE_URL=http://localhost:11434/v1  # LLM_PROVIDER=ollama (optional override)

# Slack incoming-webhook URL (optional; posting is skipped if unset)
SLACK_WEBHOOK_URL=
